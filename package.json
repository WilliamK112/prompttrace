{
  "name": "prompttrace",
  "version": "0.1.0",
  "description": "LLM observability toolkit: trace calls, aggregate metrics, export reports",
  "main": "dist/index.js",
  "bin": {
    "prompttrace": "dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "node --loader ts-node/esm src/index.ts",
    "analyze": "node dist/index.js analyze",
    "traces": "node dist/index.js traces --range 7d --limit 50",
    "failures": "node dist/index.js failures --range 7d",
    "export": "node dist/index.js export --format md --range 7d",
    "dashboard": "node dist/index.js dashboard --port 4310",
    "openclaw": "node dist/index.js openclaw --endpoint openclaw.tool.exec --"
  },
  "keywords": ["llm", "observability", "trace", "gemini", "openai"],
  "license": "MIT",
  "type": "module",
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^22.13.10",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.2"
  }
}
